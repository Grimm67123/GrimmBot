# ══════════════════════════════════════════════════════════════════════════════
# GrimmBot Alpha — Configuration
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM Configuration ────────────────────────────────────────────────────────
# Format: "provider/model-name"
LLM_MODEL=""
VISION_MODEL=""
USE_VISION=true

# ── API Keys ──────────────────────────────────────────────────────────────────
# For cloud providers, set the appropriate key, remove it if you're using local models.:
PROVIDER_API_KEY=""
# GEMINI_API_KEY=""
# ANTHROPIC_API_KEY=""
# OPENAI_API_KEY=""
# OPENROUTER_API_KEY=""

# ── Local Model Configuration ────────────────────────────────────────────────
# For local models (Recommended: Ollama, LM Studio, vLLM, LocalAI, text-gen)
# Set the base URL where the local server is running.
# You must remove PROVIDER_API_BASE if you're using a cloud provider. 
#
# Examples:
#   Ollama:     http://host.docker.internal:11434
#   LM Studio:  http://host.docker.internal:1234/v1
#   vLLM:       http://host.docker.internal:8000/v1
#   LocalAI:    http://host.docker.internal:8080/v1
#   text-gen:   http://host.docker.internal:5000/v1
PROVIDER_API_BASE=

# ── Security ──────────────────────────────────────────────────────────────────
SESSION_ENCRYPTION_KEY="change-me-to-something-secure!!"
ALLOWED_DOMAINS=""
ALLOWED_COMMANDS="python,python3,node,npm,npx,gradle,javac,java,gcc,g++,make,cargo,rustc,git,pip,cat,ls,head,tail,wc,grep,find,sed,awk,sort,uniq,diff,curl,wget,tar,unzip,zip,mkdir,cp,mv,rm,touch,chmod,echo,tee"

# ── Wormhole ──────────────────────────────────────────────────────────────────
WORMHOLE_MAX_FILE_SIZE=52428800
WORMHOLE_BLOCKED_EXTENSIONS=""
WORMHOLE_QUARANTINE=true

# ── Memory ────────────────────────────────────────────────────────────────────
MEMORY_ENABLED=true
MEMORY_MAX_ENTRIES=100
MEMORY_KEEP_AFTER_SUMMARY=20

# ── Scheduling ────────────────────────────────────────────────────────────────
SCHEDULER_PERSISTENT=true
SCHEDULER_CHECK_INTERVAL=30

# ── Agent Limits ──────────────────────────────────────────────────────────────
TASK_TIMEOUT_SECONDS=300
MAX_ITERATIONS=50
MAX_SHELL_OUTPUT_CHARS=8000
API_TIMEOUT=300

# ── General ───────────────────────────────────────────────────────────────────
TIMEZONE="UTC"
LOG_LEVEL="INFO"
VNC_PASSWORD="grimmbot"
